# DOOM Environment Variables
# Copy this to .env and fill in your keys:
#   cp .env.example .env
#
# All keys are optional. DOOM works without them but some features require them.
# This file is safe to commit — .env is not.
# Add project-specific keys as you build.

# ElevenLabs — Text-to-speech for DOOM voice (War Council, announcements)
# Get a key at: https://elevenlabs.io
ELEVENLABS_API_KEY=

# ntfy.sh — Push notifications (optional)
# Create a topic at: https://ntfy.sh
NTFY_TOPIC=
